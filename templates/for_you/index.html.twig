{% extends 'base.html.twig' %}

{% block title %}Dla Ciebie{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" media="print" onload="this.media='all'"/>
    <noscript>
        <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css"/>
    </noscript>
{% endblock %}

{% block body %}
    <section class="forYouPage">

        {# ---------- HERO ---------- #}
        <header class="hero">
            <div class="heroInner">
                <h1 class="heroTitle">Polecane książki</h1>
                {% if app.user %}
                    <p class="heroSubtitle">
                        Pozycje wybierane są na podstawie Twoich ocen. Im więcej czytasz, tym trafniejsze propozycje!
                    </p>
                {% else %}
                    <p class="heroSubtitle">
                        Zaloguj się lub zarejestruj, aby otrzymywać propozycje wybrane specjalnie dla Ciebie.
                    </p>
                    <div class="heroCtas">
                        <a class="btn btnPrimary" href="{{ path('app_login') }}">Zaloguj się</a>
                        <a class="btn btnSecondary" href="{{ path('user_register') }}">Zarejestruj się</a>
                    </div>
                {% endif %}
            </div>
        </header>

        <div class="forYouContent">

            {# ---------- Dopasowane do Ciebie ---------- #}
            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                <section class="recommendSection">
                    <h2 class="sectionTitle">Dopasowane do Ciebie</h2>
                    {% if yourBooks is not empty %}
                        {{ _self.carousel(yourBooks, 'forYou') }}
                    {% else %}
                        <p class="muted">
                            Brak rekomendacji na ten moment. Przeczytaj kilka książek lub napisz recenzję, by zobaczyć propozycje!
                        </p>
                    {% endif %}
                </section>
            {% endif %}

            {# ---------- Popularne ---------- #}
            {% if popularBooks is defined and popularBooks is not empty %}
                <section class="recommendSection">
                    <h2 class="sectionTitle">Popularne wśród czytelników</h2>
                    {{ _self.carousel(popularBooks, 'popular') }}
                </section>
            {% endif %}

            {# ---------- Najwyżej oceniane ---------- #}
            {% if topBooks is defined and topBooks is not empty %}
                <section class="recommendSection">
                    <h2 class="sectionTitle">Najwyżej oceniane</h2>
                    {{ _self.carousel(topBooks, 'top') }}
                </section>
            {% endif %}

        </div>
    </section>
{% endblock %}

{# ---------- Carousel macro ---------- #}
{% macro carousel(books, id) %}
    <div class="swiper forYouCarousel" data-carousel="{{ id }}" aria-label="Karuzela książek">
        <div class="swiper-wrapper">
            {% for book in books %}
                <div class="swiper-slide">
                    {% include 'book_card.html.twig' with { book: book } %}
                </div>
            {% endfor %}
        </div>
        <div class="swiper-button-prev" aria-label="Poprzednia książka"></div>
        <div class="swiper-button-next" aria-label="Następna książka"></div>
        <div class="swiper-pagination" aria-hidden="true"></div>
    </div>
    <noscript>
        <div class="popularGrid">
            {% for book in books %}
                <div class="popularItem">
                    {% include 'book_card.html.twig' with { book: book } %}
                </div>
            {% endfor %}
        </div>
    </noscript>
{% endmacro %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('turbo:load', function () {
            if (typeof Swiper === 'undefined') return;

            document.querySelectorAll('.forYouCarousel').forEach(function (el) {
                if (el.swiper) el.swiper.destroy(true, true);

                const slidesCount = el.querySelectorAll('.swiper-slide').length;
                const per2 = Math.min(2, slidesCount || 1);
                const per3 = Math.min(3, slidesCount || 1);
                const per4 = Math.min(4, slidesCount || 1);

                new Swiper(el, {
                    loop: slidesCount > 1,
                    slidesPerView: Math.min(1.1, slidesCount || 1),
                    centeredSlides: true,
                    spaceBetween: 12,
                    slidesOffsetBefore: 16,
                    slidesOffsetAfter: 16,
                    breakpoints: {
                        640:  { slidesPerView: per2, centeredSlides: true, slidesOffsetBefore: 0, slidesOffsetAfter: 0, spaceBetween: 16 },
                        900:  { slidesPerView: per3, spaceBetween: 16, centeredSlides: false },
                        1200: { slidesPerView: per4, spaceBetween: 16, centeredSlides: false }
                    },
                    watchOverflow: false,
                    allowTouchMove: slidesCount > 1,
                    navigation: {
                        nextEl: el.querySelector('.swiper-button-next'),
                        prevEl: el.querySelector('.swiper-button-prev'),
                    },
                    pagination: {
                        el: el.querySelector('.swiper-pagination'),
                        clickable: true
                    },
                    grabCursor: true,
                });
            });
        });
    </script>
{% endblock %}