{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}App{% endblock %}</title>
{#    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">#}
{#    <link rel="stylesheet" href="{{ asset('css/_variables.css') }}">#}
{#    <link rel="stylesheet" href="{{ asset('css/_base.css') }}">#}
{#    <link rel="stylesheet" href="{{ asset('css/_forms.css') }}">#}
{#    <link rel="stylesheet" href="{{ asset('css/_buttons.css') }}">#}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="{{ asset('js/theme-switcher.js') }}"></script>

    {# Choices.js styles #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />

    {% block stylesheets %}{% endblock %}
</head>
<body class="">
{% include 'nav.html.twig' %}

<main>
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{# Choices.js script #}
<script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const tagSelect = document.querySelector('.js-tag-select');
        if (tagSelect) {
            new Choices(tagSelect, {
                removeItemButton: true,
                placeholder: true,
                placeholderValue: 'Wybierz tagi',
                noResultsText: 'Brak wyników',
                itemSelectText: 'Wybierz'
            });
        }
    });
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
