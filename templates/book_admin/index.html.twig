{% extends 'base.html.twig' %}

{% block title %}Book index{% endblock %}

{% block body %}
    <h1>Book index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>Status</th>
                <th>Title</th>
                <th>Slug</th>
                <th>Description</th>
                <th>CoverFilename</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for book in books %}
            <tr>
                <td>{{ book.id }}</td>
                <td>{{ book.createdAt ? book.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ book.updatedAt ? book.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ book.status.value }}</td>
                <td>{{ book.title }}</td>
                <td>{{ book.slug }}</td>
                <td>{{ book.description }}</td>
                <td>{{ book.coverFilename }}</td>
                <td>
                    <a href="{{ path('book_admin_show', {'id': book.id}) }}">show</a>
                    <a href="{{ path('book_admin_edit', {'id': book.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('book_admin_new') }}">Create new</a>
{% endblock %}
