{% extends 'base.html.twig' %}

{% block title %}{{ 'title.my_profile'|trans }}{% endblock %}

{% block body %}
    <section class="profile-page">
        <h1 class="profile-title">{{ 'title.my_profile'|trans }}</h1>

        <div class="profile-container">
            {# ---------- Avatar ---------- #}
            <div class="profile-avatar">
                {% if user.avatarFilename %}
                    <img src="{{ asset('uploads/avatars/' ~ user.avatarFilename) }}" alt="Avatar użytkownika {{ user.name }}" class="profile-avatar__img">
                {% else %}
                    <div class="profile-avatar__placeholder" aria-label="{{ 'message.no_avatar'|trans }}">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="profile-avatar__icon">
                            <path fill-rule="evenodd" d="M12 2a6 6 0 100 12 6 6 0 000-12zm-9 18a9 9 0 1118 0H3z" clip-rule="evenodd" />
                        </svg>
                    </div>
                {% endif %}

                <a href="{{ path('avatar_edit') }}" class="btn btnOutlinePrimary mt-2">
                    {{ 'action.change_avatar'|trans }}
                </a>
            </div>

            {# ---------- Info ---------- #}
            <div class="profile-info">
                <dl class="profile-dl">
                    <dt>{{ 'label.name'|trans }}</dt>
                    <dd>{{ user.name }}</dd>

                    <dt>{{ 'label.email'|trans }}</dt>
                    <dd>{{ user.email }}</dd>
                </dl>

                <div class="profile-actions">
                    <a class="btn btnPrimary" href="{{ path('user_edit') }}">
                        {{ 'action.edit_profile'|trans }}
                    </a>
                    <a class="btn btnOutlineSecondary" href="{{ path('user_password') }}">
                        {{ 'action.change_password'|trans }}
                    </a>
                </div>

                {# ---------- Social accounts ---------- #}
                <div class="profile-social">
                    <h3>{{ 'label.social_profiles'|trans }}</h3>

                    {% if user.accounts is defined and user.accounts|length > 0 %}
                        <ul class="profile-social__list">
                            {% for account in user.accounts %}
                                <li class="profile-social__item">
                                    <span class="profile-social__platform">{{ account.portalSpolecznosciowy }}</span>
                                    <a class="profile-social__link" href="{{ account.link }}" target="_blank" rel="noopener noreferrer">
                                        {{ account.link }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="profile-social__empty">{{ 'message.no_social_profiles'|trans }}</p>
                    {% endif %}

                    <a href="{{ path('account_new') }}" class="btn btnOutlinePrimary mt-2">
                        {{ 'action.add_social_profile'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
