<section class="filters-form" aria-labelledby="filtersTitle">
    <h2>Filtry</h2>

    {# --- AUTHOR --- #}
    <div class="field">
        {{ form_label(form.authorTerm, null, { label_attr: { class: 'form-label' } }) }}
        {{ form_widget(form.authorTerm, {
            attr: { class: 'text-input', placeholder: 'Podaj imię lub pseudonim …' }
        }) }}
    </div>

    {# --- RATING --- #}
    {% set currentMin = app.request.get('minRating') ?: 1 %}
    <div class="field range-field">
        <label class="form-label" for="minRatingRange">
            Minimalna ocena: <span id="rating-preview">{{ currentMin }}</span>/10
        </label>

        <input id="minRatingRange" name="minRating" type="range"
               min="1" max="10" step="1"
               value="{{ currentMin }}"
               class="range-input visually-hidden">

        <div class="star-rating" data-for="minRatingRange" role="radiogroup" aria-label="Minimalna ocena">
            {% for i in 1..10 %}
                <button
                    type="button"
                    class="star {{ currentMin >= i ? 'filled' : '' }}"
                    data-value="{{ i }}"
                    role="radio"
                    aria-label="{{ i }} na 10"
                    aria-checked="{{ currentMin == i ? 'true' : 'false' }}"
                >
                    <span class="material-symbols-outlined">star</span>
                </button>
            {% endfor %}
        </div>
    </div>

    {# --- BOOK TAGS --- #}
    <div class="field tag-filter collapsed" data-filter="book-tags">
        <div class="field-head">
            <button type="button" class="section-toggle"
                    aria-expanded="false"
                    aria-controls="pills-book-tags dropdown-book-tags">
                <span class="form-label">Tagi książek</span>
                <span class="material-symbols-outlined chev" aria-hidden="true">expand_more</span>
            </button>
            <div class="field-tools">
                <span class="selected-count" aria-live="polite">0 wybranych</span>
                <button type="button" class="link-clear" data-clear>Wyczyść</button>
            </div>
        </div>

        {{ form_widget(form.tag, { attr: { class: 'hidden-tag-select' } }) }}

        <div id="pills-book-tags" class="tag-pills" role="listbox" aria-label="Tagi książek" hidden></div>
        <div id="dropdown-book-tags" class="tag-dropdown" hidden>
            <div class="tag-dropdown-inner">
                <div class="tag-options">
                    {% for choice in form.tag.vars.choices %}
                        <label class="tag-option">
                            <input type="checkbox" value="{{ choice.value }}" data-label="{{ choice.label }}">
                            <span class="tag-label">{{ choice.label }}</span>
                        </label>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# --- REVIEW TAGS --- #}
    <div class="field tag-filter collapsed" data-filter="review-tags">
        <div class="field-head">
            <button type="button" class="section-toggle"
                    aria-expanded="false"
                    aria-controls="pills-review-tags dropdown-review-tags">
                <span class="form-label">Tagi recenzji</span>
                <span class="material-symbols-outlined chev" aria-hidden="true">expand_more</span>
            </button>
            <div class="field-tools">
                <span class="selected-count" aria-live="polite">0 wybranych</span>
                <button type="button" class="link-clear" data-clear>Wyczyść</button>
            </div>
        </div>

        {{ form_widget(form.reviewTags, { attr: { class: 'hidden-tag-select' } }) }}

        <div id="pills-review-tags" class="tag-pills" role="listbox" aria-label="Tagi recenzji" hidden></div>
        <div id="dropdown-review-tags" class="tag-dropdown" hidden>
            <div class="tag-dropdown-inner">
                <div class="tag-options">
                    {% for choice in form.reviewTags.vars.choices %}
                        <label class="tag-option">
                            <input type="checkbox" value="{{ choice.value }}" data-label="{{ choice.label }}">
                            <span class="tag-label">{{ choice.label }}</span>
                        </label>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# --- SORTING --- #}
    <div class="field">
        <label class="form-label" for="sortBy">Sortuj według</label>
        <select id="sortBy" name="sortBy" class="custom-select">
            <option value="">Domyślnie</option>
            <option value="rating" {{ app.request.get('sortBy') == 'rating' ? 'selected' }}>Średnia ocena</option>
            <option value="title"  {{ app.request.get('sortBy') == 'title'  ? 'selected' }}>Tytuł</option>
        </select>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-primary">Szukaj</button>
    </div>
</section>

<script>
(function () {
    // Działa zarówno z Turbo jak i bez niego
    function init() {
        initTagFilters();
        initStarRatings();
        initCollapsible();
    }

    // ─── TAG FILTERS ────────────────────────────────────────────────────────────

    function initTagFilters() {
        document.querySelectorAll('.tag-filter').forEach(function (filter) {
            var hiddenSelect  = filter.querySelector('.hidden-tag-select');
            var pillsContainer = filter.querySelector('.tag-pills');
            var countEl        = filter.querySelector('.selected-count');
            var clearBtn       = filter.querySelector('[data-clear]');

            if (!hiddenSelect || !pillsContainer) return;

            var opts = Array.from(hiddenSelect.options);

            // Sync wartości z GET do <select> (Symfony powinno to robić automatycznie,
            // ale to zabezpieczenie na wypadek gdyby nie działało)
            var params = new URLSearchParams(window.location.search);
            var paramName = hiddenSelect.name; // np. "tag[]"
            var selectedValues = params.getAll(paramName);
            if (selectedValues.length > 0) {
                opts.forEach(function (o) {
                    o.selected = selectedValues.includes(o.value);
                });
            }

            // Zbuduj pills na podstawie stanu <select> (który teraz ma poprawne selected)
            pillsContainer.innerHTML = '';
            opts.forEach(function (o) {
                var pill = document.createElement('button');
                pill.type = 'button';
                pill.className = 'tag-pill' + (o.selected ? ' active' : '');
                pill.textContent = o.text;
                pill.dataset.value = o.value;
                pill.setAttribute('role', 'option');
                pill.setAttribute('aria-selected', o.selected ? 'true' : 'false');

                pill.addEventListener('click', function () {
                    pill.classList.toggle('active');
                    pill.setAttribute('aria-selected', pill.classList.contains('active') ? 'true' : 'false');
                    syncToSelect();
                    updateCount();
                });

                pill.addEventListener('keydown', function (e) {
                    if (e.key === ' ' || e.key === 'Enter') {
                        e.preventDefault();
                        pill.click();
                    }
                });

                pillsContainer.appendChild(pill);
            });

            function syncToSelect() {
                opts.forEach(function (o) { o.selected = false; });
                pillsContainer.querySelectorAll('.tag-pill.active').forEach(function (p) {
                    var opt = opts.find(function (o) { return o.value === p.dataset.value; });
                    if (opt) opt.selected = true;
                });
            }

            function updateCount() {
                var n = pillsContainer.querySelectorAll('.tag-pill.active').length;
                if (countEl) {
                    countEl.textContent = n + (n === 1 ? ' wybrany' : ' wybranych');
                }
                filter.classList.toggle('has-selection', n > 0);
            }

            if (clearBtn) {
                clearBtn.addEventListener('click', function () {
                    pillsContainer.querySelectorAll('.tag-pill.active').forEach(function (p) {
                        p.classList.remove('active');
                        p.setAttribute('aria-selected', 'false');
                    });
                    syncToSelect();
                    updateCount();
                });
            }

            // Nie wywołujemy syncToSelect() przy inicjalizacji – <select> już ma dobry stan
            updateCount();
        });
    }

    // ─── STAR RATINGS ───────────────────────────────────────────────────────────

    function initStarRatings() {
        document.querySelectorAll('.star-rating').forEach(initStarRating);
    }

    function initStarRating(container) {
        var inputId  = container.getAttribute('data-for');
        var input    = document.getElementById(inputId);
        var preview  = document.getElementById('rating-preview');
        var stars    = Array.from(container.querySelectorAll('.star'));
        if (!input) return;

        var clamp = function (v) {
            return Math.max(Number(input.min) || 1, Math.min(Number(input.max) || 10, v));
        };
        var value = clamp(Number(input.value) || 1);

        function apply(v) {
            value = clamp(v);
            input.value = value;
            if (preview) preview.textContent = value;
            stars.forEach(function (s, i) {
                var filled = i < value;
                s.classList.toggle('filled', filled);
                s.setAttribute('aria-checked', (i + 1) === value ? 'true' : 'false');
                s.tabIndex = (i + 1) === value ? 0 : -1;
            });
        }

        function highlight(tempVal) {
            stars.forEach(function (s, i) {
                s.classList.toggle('filled', i < tempVal);
            });
            if (preview) preview.textContent = tempVal;
        }

        stars.forEach(function (star, i) {
            var v = i + 1;
            star.addEventListener('click',      function () { apply(v); });
            star.addEventListener('mouseenter', function () { highlight(v); });
            star.addEventListener('mouseleave', function () { apply(value); });
            star.addEventListener('keydown', function (e) {
                if (e.key === ' ' || e.key === 'Enter')                    { e.preventDefault(); apply(v); }
                else if (e.key === 'ArrowRight' || e.key === 'ArrowUp')    { e.preventDefault(); apply(value + 1); focusStar(value); }
                else if (e.key === 'ArrowLeft'  || e.key === 'ArrowDown')  { e.preventDefault(); apply(value - 1); focusStar(value); }
                else if (e.key === 'Home')                                  { e.preventDefault(); apply(1);  focusStar(1); }
                else if (e.key === 'End')                                   { e.preventDefault(); apply(10); focusStar(10); }
            });
        });

        function focusStar(v) {
            var el = stars[clamp(v) - 1];
            if (el) el.focus();
        }

        apply(value);
    }

    // ─── COLLAPSIBLE TAG SECTIONS ────────────────────────────────────────────────

    function initCollapsible() {
        var STORAGE_KEY = 'filters-collapsed-state-v2';
        var saved = {};
        try { saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch (e) {}

        document.querySelectorAll('.tag-filter').forEach(function (section) {
            var key    = section.dataset.filter || 'unknown';
            var toggle = section.querySelector('.section-toggle');
            var pills  = section.querySelector('.tag-pills');
            var drop   = section.querySelector('.tag-dropdown');
            if (!toggle) return;

            var shouldExpand = saved[key] === 'expanded';
            setCollapsed(!shouldExpand);

            toggle.addEventListener('click', function () {
                var expanded = toggle.getAttribute('aria-expanded') === 'true';
                setCollapsed(expanded);
            });

            toggle.addEventListener('keydown', function (e) {
                if (e.key === 'ArrowLeft')  { e.preventDefault(); setCollapsed(true); }
                if (e.key === 'ArrowRight') { e.preventDefault(); setCollapsed(false); }
            });

            function setCollapsed(collapsed) {
                section.classList.toggle('collapsed', collapsed);
                toggle.setAttribute('aria-expanded', String(!collapsed));
                if (pills) pills.hidden = collapsed;
                if (drop)  drop.hidden  = collapsed;
                saved[key] = collapsed ? 'collapsed' : 'expanded';
                try { localStorage.setItem(STORAGE_KEY, JSON.stringify(saved)); } catch (e) {}
            }
        });
    }

    // ─── BOOTSTRAP ──────────────────────────────────────────────────────────────
    // Obsługuje zarówno zwykłe ładowanie jak i nawigację przez Turbo

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
    document.addEventListener('turbo:load', init);

})();
</script>
