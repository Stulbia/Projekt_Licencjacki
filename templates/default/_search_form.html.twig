

{% block body %}
    {{ form_start(form) }}
    {% if false == form.vars.valid %}
        {% include 'default/_single_alert_message.html.twig' with {
            type: 'danger',
            message: 'message.form_error'|trans,
        }%}
    {% endif %}
    {{ form_widget(form) }}
    <div class="formGroup row floatSmRight">
        <input type="submit" value="{{ submit_label }}" class="btn btnPrimary"/>
    </div>
    {% if back_to_list_path|default(false) %}
        <div class="formGroup row floatSmLeft">
            <a href="{{ url(back_to_list_path) }}" class="btn btnSecondary">
                {{ 'action.back_to_list'|trans }}
            </a>
        </div>
    {% endif %}
    {{ form_end(form) }}
{% endblock %}