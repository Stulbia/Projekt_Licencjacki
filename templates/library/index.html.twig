{# templates/book/library.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Biblioteczka{% endblock %}

{% block body %}
    <h1>Biblioteczka</h1>

    <div class="searchLayout">
        <aside class="searchForm">
            {{ form_start(form, { method:'get', attr:{ class:'filter-form' } }) }}

            <h2 class="filterHeading">Filtry</h2>

            {# --- PRZYCISKI --- #}
            <div class="formActions">
                <button type="submit" class="btn btnPrimary">🔍︎  Szukaj</button>
                <a href="{{ path(app.request.attributes.get('_route')) }}" class="btn btnReset">Wyczyść</a>
            </div>

            {# --- TAGI (dropdown z checkboxami) --- #}
            <div class="formGroup tagFilter">
                {{ form_widget(form.tag, { attr:{ class:'hidden-tag-select' } }) }}

                <button type="button" id="tagToggle" class="btnPrimary tagToggle" aria-expanded="false">
                    Wybierz tagi
                </button>

                <div id="tagPills" class="tagPills"></div>

                <div id="tagDropdown" class="tagDropdown">
                    {% for choice in form.tag.vars.choices %}
                        <label class="tagOption">
                            <input type="checkbox" value="{{ choice.value }}" data-label="{{ choice.label }}">
                            {{ choice.label }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            {# --- MINIMALNA OCENA (suwak) --- #}
            <div class="formGroup">
                <label class="formLabel" for="minRatingRange">
                    Minimalna ocena:
                    <span id="ratingPreview">{{ app.request.get('minRating') ?: 1 }}</span>/10
                </label>

                <input type="range" id="minRatingRange" name="minRating" min="1" max="10" step="1" value="{{ app.request.get('minRating') ?: 1 }}" class="rangeInput">
            </div>

            {# --- SORTOWANIE --- #}
            <div class="formGroup">
                <label class="formLabel" for="sortBy">Sortuj według</label>
                <select id="sortBy" name="sortBy" class="customSelect">
                    <option value="">Domyślnie</option>
                    <option value="rating"    {{ app.request.get('sortBy') == 'rating'    ? 'selected' }}>Średnia ocena</option>
                    <option value="title"     {{ app.request.get('sortBy') == 'title'     ? 'selected' }}>Tytuł</option>
                    <option value="updatedAt" {{ app.request.get('sortBy') == 'updatedAt' ? 'selected' }}>Ostatnia aktualizacja</option>
                </select>
            </div>

            {# --- AUTOR --- #}
            <div class="formGroup">
                {{ form_label(form.authorTerm, null, { label_attr:{ class:'formLabel' } }) }}
                {{ form_widget(form.authorTerm, { attr:{ class:'customSelect' } }) }}
            </div>

            {{ form_end(form) }}
        </aside>

        <section class="searchResults">
            <h2>Wyniki</h2>

            {% if pagination.items is not empty %}
                <div class="bookGrid">
                    {% for relation in pagination.items %}
                        {% set book = relation.book %}
                        <div class="bookCard">
{#                            {% if book.coverFilename %}#}
{#                                <img src="{{ asset('uploads/' ~ book.coverFilename) }}" alt="Okładka książki {{ book.title }}" class="bookCover">#}
{#                            {% endif %}#}
                            {% if book.coverFilename %}
                                <img src="{{ asset('uploads/covers/' ~ book.coverFilename) }}" class="book-cover"
                                     alt="Okładka: {{ book.title }}">
                            {% else %}
                                <img src="{{ asset('uploads/defaultCover.svg') }}" alt="Okladka {{ book.title }}">
                            {% endif %}
                            <h3 class="bookTitle">
                                <a href="{{ path('book_show', { slug: book.slug }) }}">
                                    {{ book.title }}
                                </a>
                            </h3>
                            <p class="bookAuthor">{{ book.author ?? 'Nieznany autor' }}</p>
                        </div>
                    {% endfor %}
                </div>

                <div class="pagination">
                    {{ knp_pagination_render(pagination) }}
                </div>
            {% else %}
                <p>Brak wyników.</p>
            {% endif %}
        </section>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            /* --- referencje --- */
            const toggleBtn    = document.getElementById('tagToggle');
            const dropdown     = document.getElementById('tagDropdown');
            const pillsBox     = document.getElementById('tagPills');
            const hiddenSelect = document.querySelector('.hidden-tag-select');

            /* --- helper: render pigułek --- */
            const renderPills = () => {
                pillsBox.innerHTML = '';
                [...hiddenSelect.selectedOptions].forEach(opt => {
                    const pill = document.createElement('span');
                    pill.className = 'tagPill';
                    pill.innerHTML = `${opt.text} <span class="remove" data-value="${opt.value}">×</span>`;
                    pillsBox.appendChild(pill);
                });
            };

            /* --- toggle dropdown --- */
            toggleBtn?.addEventListener('click', () => {
                dropdown.classList.toggle('open');
                toggleBtn.setAttribute('aria-expanded', dropdown.classList.contains('open'));
            });

            /* --- klik w checkbox --- */
            dropdown?.addEventListener('change', e => {
                const box = e.target;
                if (!box || box.type !== 'checkbox') return;
                const value = box.value;
                [...hiddenSelect.options].forEach(opt => {
                    if (opt.value === value) opt.selected = box.checked;
                });
                renderPills();
            });

            /* --- usuwanie z pigułki --- */
            pillsBox?.addEventListener('click', e => {
                if (!e.target.classList.contains('remove')) return;
                const value = e.target.dataset.value;
                dropdown.querySelector(`input[value="${value}"]`).checked = false;
                [...hiddenSelect.options].find(opt => opt.value === value).selected = false;
                renderPills();
            });

            /* --- klik poza dropdown → zamknij --- */
            document.addEventListener('click', e => {
                if (!dropdown.contains(e.target) && !toggleBtn.contains(e.target)) {
                    dropdown.classList.remove('open');
                    toggleBtn.setAttribute('aria-expanded', 'false');
                }
            });

            /* --- inicjalizacja --- */
            renderPills();

            /* --- live preview suwaka --- */
            const ratingRange   = document.getElementById('minRatingRange');
            const ratingPreview = document.getElementById('ratingPreview');
            ratingRange?.addEventListener('input', () => ratingPreview.textContent = ratingRange.value);
        });
    </script>
{% endblock %}
