      <script>
        /**
         * Skrypt obsługujący pola wyboru tagów (zarówno książek, jak i recenzji).
         * Działa dla dowolnej liczby bloków .tagFilter, bo każdy blok działa w swojej
         * własnej, zamkniętej przestrzeni – nie ma już konfliktu identyfikatorów.
         */
        document.addEventListener('DOMContentLoaded', () => {


            // document.querySelectorAll('.shelf-toggle').forEach(toggle => {
            //     toggle.addEventListener('click', () => {
            //         const shelf = toggle.nextElementSibling;
            //         shelf.classList.toggle('collapsed');
            //     });
            // });

            document.querySelectorAll('.shelf-toggle').forEach(toggle => {
                const shelf = toggle.nextElementSibling;

                // Dodaj klasę open na start jeśli nie ma collapsed
                if (!shelf.classList.contains('collapsed')) {
                    toggle.classList.add('open');
                }

                toggle.addEventListener('click', () => {
                    shelf.classList.toggle('collapsed');
                    toggle.classList.toggle('open');

                    // Można też dynamicznie podmieniać znak, ale dzięki rotate nie trzeba
                    // const arrow = toggle.querySelector('.arrow');
                    // arrow.textContent = shelf.classList.contains('collapsed') ? '▼' : '▲';
                });
            });

            /**
             * Dla każdego kontenera .tagFilter podpinamy niezależny zestaw listenerów.
             */
            document.querySelectorAll('.tagFilter').forEach(filter => {
                /* --- referencje --- */
                const toggleBtn    = filter.querySelector('.tagToggle');
                const dropdown     = filter.querySelector('.tagDropdown');
                const pillsBox     = filter.querySelector('.tagPills');
                const hiddenSelect = filter.querySelector('.hidden-tag-select');

                /* --- helper: renderuje pigułki z zaznaczonymi tagami --- */
                const renderPills = () => {
                    pillsBox.innerHTML = '';
                    Array.from(hiddenSelect.selectedOptions).forEach(opt => {
                        const pill = document.createElement('span');
                        pill.className = 'tagPill';
                        pill.innerHTML = `${opt.text} <span class="remove" data-value="${opt.value}">×</span>`;
                        pillsBox.appendChild(pill);
                    });
                };

                /* --- toggle dropdown --- */
                toggleBtn.addEventListener('click', () => {
                    dropdown.classList.toggle('open');
                    const expanded = dropdown.classList.contains('open');
                    toggleBtn.setAttribute('aria-expanded', expanded);
                });

                /* --- klik w checkbox --- */
                dropdown.addEventListener('change', e => {
                    const box   = e.target;
                    if (box.tagName !== 'INPUT') return; // bezpieczeństwo
                    const value = box.value;

                    /* synchronizuj ukryty <select> */
                    Array.from(hiddenSelect.options).forEach(opt => {
                        if (opt.value === value) opt.selected = box.checked;
                    });

                    renderPills();
                });

                /* --- usuwanie tagu z pigułki --- */
                pillsBox.addEventListener('click', e => {
                    if (!e.target.classList.contains('remove')) return;
                    const value = e.target.dataset.value;

                    /* odznacz checkbox + <select> */
                    dropdown.querySelector(`input[value="${value}"]`).checked = false;
                    Array.from(hiddenSelect.options).find(opt => opt.value === value).selected = false;

                    renderPills();
                });

                /* --- klik poza dropdown → zamknij --- */
                document.addEventListener('click', e => {
                    if (!filter.contains(e.target)) {
                        dropdown.classList.remove('open');
                        toggleBtn.setAttribute('aria-expanded', 'false');
                    }
                });

                /* --- inicjalizacja z już-wybranymi (np. po powrocie z wyników) --- */
                renderPills();


            });
            const ratingInput = document.getElementById('minRatingRange');
            const ratingPreview = document.getElementById('ratingPreview');

            if (ratingInput && ratingPreview) {
                ratingInput.addEventListener('input', () => {
                    ratingPreview.textContent = ratingInput.value;
                });
            }
        });
    </script>

        </div>

    <div class="library-sidebar">
        {# ——— FORMULARZ ——— #}
        <div class="generatedForm">
            {{ form_start(form, {
                method: 'get',
                action: path(app.request.attributes.get('_route')),
                attr: {class: 'filter-form'}
            }) }}
        </div>

        <h2 class="filterHeading">Filtry</h2>

        {# — przyciski — #}
        <div class="formActions">
            <button type="submit" class="btn btnPrimary">🔍︎ Szukaj</button>
        </div>

        <div class="formGroup">
            {{ form_label(form.title, null, {label_attr: {class: 'formLabel'}}) }}
            {{ form_widget(form.title, {
                attr: {class: 'textInput', placeholder: 'Wichrowe wzgorza...'}
            }) }}
        </div>
        {# — AUTOR — #}
        <div class="formGroup">
            {{ form_label(form.authorTerm, null, {label_attr: {class: 'formLabel'}}) }}
            {{ form_widget(form.authorTerm, {
                attr: {class: 'textInput', placeholder: 'Brandon / King …'}
            }) }}
        </div>

        {# — TAGI KSIĄŻKI — #}
        <div class="formGroup tagFilter" data-filter="bookTags">
            {{ form_widget(form.tag, {attr: {class: 'hidden-tag-select'}}) }}

            <button type="button" class="btnPrimary tagToggle" aria-expanded="false">
                Wybierz tagi
            </button>

            <div class="tagPills"></div>

            <div class="tagDropdown">
                {% for choice in form.tag.vars.choices %}
                    <label class="tagOption">
                        <input type="checkbox" value="{{ choice.value }}" data-label="{{ choice.label }}">
                        {{ choice.label }}
                    </label>
                {% endfor %}
            </div>
        </div>

        {# — MINIMALNA OCENA — #}
        <div class="formGroup">
            <label class="formLabel" for="minRatingRange">
                Minimalna ocena:
                <span id="ratingPreview">{{ app.request.get('minRating') ?: 1 }}</span>/10
            </label>
            <input id="minRatingRange" name="minRating" type="range"
                   min="1" max="10" step="1"
                   value="{{ app.request.get('minRating') ?: 1 }}"
                   class="rangeInput">
        </div>

        {# — TAGI RECENZJI — #}
        <div class="formGroup tagFilter" data-filter="reviewTags">
            {{ form_widget(form.reviewTags, {attr: {class: 'hidden-tag-select'}}) }}

            <button type="button" class="btnPrimary tagToggle" aria-expanded="false">
                Wybierz tagi recenzji
            </button>

            <div class="tagPills"></div>

            <div class="tagDropdown">
                <div class="tagDropdownInner">
                    <div class="tagOptions">
                        {% for choice in form.reviewTags.vars.choices %}
                            <label class="tagOption">
                                <input type="checkbox" value="{{ choice.value }}" data-label="{{ choice.label }}">
                                <span class="tagLabel">{{ choice.label }}</span>
                            </label>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        {# — SORTOWANIE — #}
        <div class="formGroup">
            <label class="formLabel" for="sortBy">Sortuj według</label>
            <select id="sortBy" name="sortBy" class="customSelect">
                <option value="">Domyślnie</option>
                <option value="rating"    {{ app.request.get('sortBy') == 'rating'    ? 'selected' }}>Średnia ocena</option>
                <option value="title"     {{ app.request.get('sortBy') == 'title'     ? 'selected' }}>Tytuł</option>
            </select>
        </div>

        {{ form_rest(form) }} {# CSRF & ukryte pola #}
        {{ form_end(form, {render_rest: false}) }}
    </div>



{% endblock %}