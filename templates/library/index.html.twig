{% extends 'base.html.twig' %}

{% block title %}Biblioteka{% endblock %}

{% block body %}
    <div>


            <h1>Biblioteczka</h1>


                <section >

                    {% if pagination.items is not empty %}

                        {% set toRead = [] %}
                        {% set reading = [] %}
                        {% set read = [] %}


                        {% for relation in pagination.items %}
                            {% if relation.status.value == 'to_read' %}
                                {% set toRead = toRead|merge([relation]) %}
                            {% elseif relation.status.value == 'reading' %}
                                {% set reading = reading|merge([relation]) %}
                            {% elseif relation.status.value == 'read' %}
                                {% set read = read|merge([relation]) %}
                            {% endif %}
                        {% endfor %}


                        <section >
                            <h2 >
                                Do przeczytania
                            </h2>
                           <div >
                                {% for relation in toRead %}
                                    {% set book = relation.book  %}

                                    {% include 'book_card.html.twig' %}

                                {% endfor %}
                            </div>
                        </section>

                        <section>
                            <h2 >Czytam</h2>
                            <div class = "shelf-content">     <div class="book-shelf-row">
                                {% for relation in reading %}
                                    {% set book = relation.book  %}
                                    {% include 'book_card.html.twig' %}

                                {% endfor %}
                            </div>
                            </div>
                        </section>

                        <section class="bookshelf">
                            <h2>  Przeczytane</h2>
                            <div class = "shelf-content"><div class="book-shelf-row">
                                {% for relation in read %}
                                    {% set book = relation.book  %}

                                    {% include 'book_card.html.twig' %}


                                {% endfor %}
                            </div>
                            </div>
                        </section>

                        {{ knp_pagination_render(pagination) }}
                    {% else %}
                        <p>Brak wyników wyszukiwania.</p>
                    {% endif %}

                </section>
            </div>


    <div class="search-form">
        <h1><b style="color: #fa0000"> /debilu wstaw tutaj szablon forms </b> </h1>
    </div>
