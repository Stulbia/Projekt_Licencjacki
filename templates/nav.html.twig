<nav class="navBar">
    <div class="navLogo">
       <a href="{{ path('homepage') }}"> <span class="material-symbols-outlined">menu_book</span> Biblioteka</a>
    </div>

    {# Hamburger on the right #}
    <button id="hamburger"
            class="navHamburger"
            aria-label="Menu"
            aria-controls="navLinks"
            aria-expanded="false">
        <span class="ms-icon material-symbols-outlined" aria-hidden="true">menu</span>
    </button>


    {# Collapsible links #}
    <div id="navLinks" class="navLinks" data-open="false">
        <a class="navLink" href="{{ path('homepage') }}">Strona Głowna</a>
        <a class="navLink" href="{{ path('for_you_index') }}">Polecane</a>
        <a class="navLink" href="{{ path('book_search') }}">Szukaj</a>

        {% if app.user %}
            <a class="navLink" href="{{ path('library_index') }}">Biblioteczka</a>
            <a class="navLink" href="{{ path('review_index') }}">Twoje Recenzje</a>
            <a class="navLink" href="{{ path('user_index') }}">Twój profil</a>
            <a class="navLink loginBtn" href="{{ path('app_logout') }}">Wyloguj</a>
        {% else %}
            <a class="navLink" href="{{ path('app_login') }}">Zaloguj</a>
            <a class="navLink loginBtn" href="{{ path('user_register') }}">Zarejestruj</a>
        {% endif %}
    </div>
</nav>

<script>
    (function () {
        const btn = document.getElementById('hamburger');
        const panel = document.getElementById('navLinks');
        const icon = btn?.querySelector('.ms-icon');
        if (!btn || !panel || !icon) return;

        function setOpen(open) {
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            panel.setAttribute('data-open', open ? 'true' : 'false');
            btn.setAttribute('aria-label', open ? 'Zamknij menu' : 'Menu');
            icon.textContent = open ? 'close' : 'menu'; // 👈 switch icon
        }

        btn.addEventListener('click', () => {
            const open = btn.getAttribute('aria-expanded') === 'true';
            setOpen(!open);
        });

        panel.addEventListener('click', (e) => {
            if (e.target.closest('a')) setOpen(false);
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') setOpen(false);
        });

        // Reset when switching to desktop
        const mq = window.matchMedia('(min-width: 769px)');
        mq.addEventListener('change', (ev) => { if (ev.matches) setOpen(false); });
    })();
</script>
