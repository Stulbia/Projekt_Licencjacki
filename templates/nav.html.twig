{# templates/partials/nav.html.twig #}
<nav>
    <ul>
        <li><a href="{{ path('book_index') }}">Books</a></li>
        <li><a href="{{ path('tag_index') }}">Tags</a></li>
        <li><a href="{{ path('review_index') }}">Reviews</a></li>
        {% if is_granted('ROLE_ADMIN') %}
            <li><a href="{{ path('user_list') }}">Users</a></li>
        {% endif %}
        {% if app.user %}
            <li><a href="{{ path('user_index') }}">My Profile</a></li>
            <li><a href="{{ path('app_logout') }}">Logout</a></li>
        {% else %}
            <li><a href="{{ path('app_login') }}">Login</a></li>
            <li><a href="{{ path('user_register') }}">Register</a></li>
        {% endif %}
    </ul>
</nav>
