{% extends 'base.html.twig' %}

{% block title %}Delete Tag{% endblock %}

{% block body %}
    <h1>Delete Tag: {{ tag.title }}</h1>

    <p>Are you sure you want to delete this tag?</p>

    {{ form_start(form) }}
    <button type="submit">Yes, delete</button>
    {{ form_end(form) }}

    <a href="{{ path('tag_index') }}">Cancel</a>
{% endblock %}
