{% extends 'base.html.twig' %}

{% block title %}Witamy w Bibliotece!{% endblock %}

{# --- Styles: include Swiper + a tiny carousel tweak stylesheet --- #}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css"/>

{% endblock %}

{% block body %}

    {# ---------------- HERO ---------------- #}
    <section class="hero">
        <h1>Odkrywaj, oceniaj i dziel się książkami</h1>

        {% if not app.user %}
            <p>Dołącz do naszej społeczności i odkrywaj najlepsze lektury!</p>
            <a href="{{ path('user_register') }}" class="register-btn">Załóż konto</a>
        {% else %}
            <p>Znajdź nowe pozycje, wybrane specjalnie dla Ciebie!</p>
            <a href="{{ path('for_you_index') }}" class="register-btn">Przeglądaj…</a>
        {% endif %}
    </section>

    {# ---------------- POPULAR (Swiper carousel with mobile “peek”) ---------------- #}
    <section class="popular container">
        <h2>Najpopularniejsze książki</h2>

        {% if popularBooks is not empty %}
            <div class="swiper myPopularCarousel" aria-label="Karuzela popularnych książek">
                <div class="swiper-wrapper">
                    {% for book in popularBooks %}
                        <div class="swiper-slide">
                            {% include 'book_card.html.twig' with { book: book } %}
                        </div>
                    {% endfor %}
                </div>
                <div class="swiper-button-prev" aria-label="Poprzednia książka"></div>
                <div class="swiper-button-next" aria-label="Następna książka"></div>
                <div class="swiper-pagination" aria-hidden="true"></div>
            </div>

            <noscript>
                <div class="popularGrid">
                    {% for book in popularBooks %}
                        <div class="popularItem">
                            {% include 'book_card.html.twig' with { book: book } %}
                        </div>
                    {% endfor %}
                </div>
            </noscript>
        {% else %}
            <p class="muted">Brak danych o popularnych książkach — dodaj kilka pozycji lub recenzji, aby zobaczyć rekomendacje.</p>
        {% endif %}
    </section>

    {# ---------------- FEATURES ---------------- #}
    {% set features = [
        {
            path: path('book_search'),
            icon: 'newsstand',
            title: 'Setki książek',
            text: 'Przeglądaj naszą stale rosnącą kolekcję książek z recenzjami użytkowników.'
        },
        {
            path: path('book_search'),
            icon: 'star',
            title: 'Recenzje i oceny',
            text: 'Sprawdzaj opinie innych czytelników i dziel się swoimi wrażeniami.'
        },
        app.user
        ? {
            path: path('user_index'),
            icon: 'account_circle',
            title: 'Twoje konto',
            text: 'Zobacz szczegóły swojego konta.'
        }
        : {
            path: path('user_register'),
            icon: 'account_circle',
            title: 'Dołącz do społeczności',
            text: 'Załóż darmowe konto i bądź częścią książkowej społeczności online.'
        }
    ] %}

    <section class="features">
        {% for feature in features %}
            <a href="{{ feature.path }}" class="feature-card">
                <span class="material-symbols-outlined">{{ feature.icon }}</span>
                <h3>{{ feature.title }}</h3>
                <p>{{ feature.text }}</p>
            </a>
        {% endfor %}
    </section>

    {# ---------------- ABOUT ---------------- #}
    <section id="about" class="about">
        <h2>O projekcie</h2>
        <p>
            Biblioteka to miejsce dla czytelników, którzy chcą odkrywać nowe tytuły, dzielić się opiniami i
            budować własną listę lektur. Korzystamy z recenzji społeczności oraz Twoich ocen, aby proponować
            trafniejsze rekomendacje.
        </p>
        <p>
            Przeglądaj popularne pozycje, wyszukuj po tagach i autorach, a potem dodawaj książki do swojej
            biblioteki z oznaczeniem statusu czytania.
        </p>
        <p class="muted">
            Masz pomysł na nową funkcję albo znalazłeś błąd? Daj nam znać — razem ulepszamy doświadczenie czytelnicze.
        </p>
    </section>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
    <script>
        (function () {
            const slidesCount = {{ popularBooks|length|default(0) }};
            const per2 = Math.min(2, slidesCount || 1);
            const per3 = Math.min(3, slidesCount || 1);
            const per4 = Math.min(4, slidesCount || 1);

            new Swiper('.myPopularCarousel', {
                // only loop if we actually have something to loop
                loop: slidesCount > 1,

                // mobile-first “peek”
                slidesPerView: Math.min(1.1, slidesCount || 1),
                centeredSlides: true,
                spaceBetween: 12,
                slidesOffsetBefore: 16,
                slidesOffsetAfter: 16,

                breakpoints: {
                    640:  {
                        slidesPerView: per2,
                        centeredSlides: false,
                        slidesOffsetBefore: 0,
                        slidesOffsetAfter: 0,
                        spaceBetween: 16
                    },
                    900:  { slidesPerView: per3, spaceBetween: 16, centeredSlides: false },
                    1200: { slidesPerView: per4, spaceBetween: 16, centeredSlides: false }
                },

                // keep controls active even if slides == slidesPerView
                watchOverflow: false,
                allowTouchMove: slidesCount > 1,

                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev'
                },
                pagination: { el: '.swiper-pagination', clickable: true },
                grabCursor: true,
                autoHeight: true
            });
        })();
    </script>
{% endblock %}

