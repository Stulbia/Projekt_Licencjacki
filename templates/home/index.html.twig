{% extends 'base.html.twig' %}

{% block title %}Witamy w Bibliotece!{% endblock %}

{# --- Asset blocks ------------------------------------------------------ #}
{% block stylesheets %}
    {{ parent() }}
    {# Swiper core CSS – adds minimal extra weight and plays nicely with existing styles #}
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css"/>

    <style>
        /* --------------------------------------------------------------
           1. Swiper theme colour (arrows + active bullet)
              Switch to #fff for white if needed.
        -------------------------------------------------------------- */
        :root {
            --swiper-theme-color: #000;
        }

        /* 2. Pagination bullets – keep inactive bullets visible */
        .swiper-pagination-bullet {
            background: rgba(0, 0, 0, 0.25);
            opacity: 1;
        }
        .swiper-pagination-bullet-active {
            background: var(--swiper-theme-color);
        }

        /* 3. FLEX wrapper so arrows sit *next to* the carousel */
        .carousel-wrapper {
            display: flex;
            align-items: center;
            gap: 1rem;          /* space between arrow ⇄ slider ⇄ arrow */
        }
        .carousel-wrapper .swiper {
            flex: 1 1 0;        /* take remaining width */
        }
        /* Place arrows statically (no overlay) and give click area */
        .carousel-wrapper .swiper-button-prev,
        .carousel-wrapper .swiper-button-next {
            position: static;   /* override Swiper absolute positioning */
            width: 42px;
            height: 42px;
            cursor: pointer;
        }
    </style>
{% endblock %}

{# ----------------------------------------------------------------------- #}
{% block body %}

    <section class="hero animate-fadeInUp">

        <h1>Odkrywaj, oceniaj i dziel się książkami</h1>

        {% if app.user %}
        <p>Dołącz do naszej społeczności i odkrywaj najlepsze lektury!</p>
        <a href="{{ path('user_register') }}" class="register-btn">Załóż konto</a>
        {% else %}
        <p>Znajdz nowe pozycje,wybrane specjalnie dla ciebiey!</p>
        <a href="{{ path('for_you_index') }}" class="register-btn">Załóż konto</a>
    {% endif %}
    </section>

    <section class="dashboard-content animate-fadeInUp">
        <h2>Najpopularniejsze książki</h2>

        {% if popularBooks is not empty %}
            {# -------------------------------------------------------------------
               FLEX wrapper: arrows « slider » arrows
            ------------------------------------------------------------------- #}
            <div class="carousel-wrapper">
                <div class="swiper-button-prev" tabindex="0" role="button" aria-label="Poprzednia książka"></div>

                <div class="swiper myBooksCarousel">
                    <div class="swiper-wrapper">
                        {% for book in popularBooks %}
                            <div class="swiper-slide">
                                <div class="book-card animate-fadeInUp" style="animation-delay: {{ loop.index0 * 0.1 }}s">
                                    {% if book.coverFilename %}
                                        <img src="{{ asset('uploads/covers/' ~ book.coverFilename) }}"
                                             alt="Okładka {{ book.title }}"
                                             class="book-cover">
                                    {% else%}
                                        <img src="{{ asset('uploads/defaultCover.svg') }}" alt="Domyślna okładka książki {{ book.title }}">
                                    {% endif %}


                                    <h3>
                                        <a href="{{ path('book_show', { slug: book.slug }) }}">
                                            {{ book.title }}
                                        </a>
                                    </h3>
                                    {% if book.author %}
                                        <a href="{{ path('author_show', { id: book.author.id }) }}" class="author">{{ book.author }}</a>
                                    {% else %}
                                        Nieznany autor
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="swiper-button-next" tabindex="0" role="button" aria-label="Następna książka"></div>
            </div>

            {# Pagination bullets below the whole wrapper #}
            <div class="swiper-pagination"></div>
        {% endif %}
    </section>

    <section class="features animate-fadeInUp">
        <a href="{{ path('book_search') }}" class="feature-card">
            <span class="icon">📚</span>
            <h3>Setki książek</h3>
            <p>Przeglądaj naszą stale rosnącą kolekcję książek z recenzjami użytkowników.</p>
        </a>

        <a href="{{ path('book_search') }}" class="feature-card">
            <span class="icon">⭐</span>
            <h3>Recenzje i oceny</h3>
            <p>Sprawdzaj opinie innych czytelników i dziel się swoimi wrażeniami.</p>
        </a>

        {% if app.user %}
        <a href="{{ path('user_index') }}" class="feature-card">
            <span class="icon">👤</span>
            <h3>Twoje konto</h3>
            <p>Zobacz szczegóły swojego konta.</p>
        </a>
            {% else %}
            <a href="{{ path('user_register') }}" class="feature-card">
                <span class="icon">👤</span>
                <h3>Dołącz do społeczności</h3>
                <p>Załóż darmowe konto i bądź częścią książkowej społeczności online.</p>
            </a>
                {% endif %}

    </section>
{% endblock %}

{# ----------------------------------------------------------------------- #}
{% block javascripts %}
    {{ parent() }}
    {# Swiper core JS #}
    <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new Swiper('.myBooksCarousel', {
                slidesPerView: 1,
                spaceBetween: 20,
                loop: true,
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                breakpoints: {
                    640: {
                        slidesPerView: 2,
                    },
                    1024: {
                        slidesPerView: 4,
                    }
                }
            });
        });
    </script>
{% endblock %}
