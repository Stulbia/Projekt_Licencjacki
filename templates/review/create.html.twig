{% extends 'book/show.html.twig' %}

{% block title %}Recenzja: {{ book.title }}{% endblock %}
{% block review_buttons%}
{% set formVisibleReview = true %}
{% endblock %}
{% block add_review %}
    <section class="review-form-container">
        <h2>Napisz recenzję: <em>{{ book.title }}</em></h2>
        {{ form_start(form, { attr: { class: 'review-form' } }) }}

        {# ---------- Rating: hidden Symfony field + pretty star buttons ---------- #}
        {% set current = form.rating.vars.value ?? 5 %}
        {{ form_widget(form.rating, { type: 'hidden' }) }}

        <div class="rating-row">
            <div id="starRating" class="star-rating" role="radiogroup" aria-label="Ocena (1–10)">
                {% for i in 1..10 %}
                    <button
                            type="button"
                            class="star {{ current >= i ? 'filled' : '' }}"
                            data-value="{{ i }}"
                            role="radio"
                            aria-label="{{ i }} na 10"
                            aria-checked="{{ current == i ? 'true' : 'false' }}"
                            tabindex="{{ current == i ? '0' : '-1' }}"
                    >
                        <span class="material-symbols-outlined">star</span>
                    </button>
                {% endfor %}
                <span id="ratingNumber" class="rating-number">{{ current }}/10</span>
            </div>

            {{ form_errors(form.rating) }}
        </div>

        {# ---------- Comment ---------- #}
        {{ form_row(form.comment) }}

{#        {{ form_row(form.reviewTags) }}#}


        <div class="form-group" data-turbo="false">
            {{ form_label(form.reviewTags, null, { label_attr: { class: 'formLabel' } }) }}

            <div class="tag-pills" id="reviewTagsField" data-enhance="tag-pills" data-turbo="true">
                {% for child in form.reviewTags %}
                    <label class="tagPill">
                        {{ form_widget(child, { attr: { class: 'tagPillInput' } }) }}
{#                        <span class="tagPillText">{{ child.vars.label }}</span>#}
                    </label>
                {% endfor %}
            </div>

            {{ form_errors(form.reviewTags) }}
        </div>


<div class="button-container" data-turbo="false">
        <button type="submit" class="btn add-review"> Zapisz</button>
</div>
        {# Normal end -> includes CSRF & any hidden fields; won't duplicate rendered fields #}
        {{ form_end(form) }}
    </section>



    <script type="module">
        const container = document.querySelector('[data-enhance="tag-pills"]');
        if (container) {
            container.querySelectorAll('.tagPill').forEach(label => {
                const input = label.querySelector('input[type="checkbox"]');
                if (!input) return;

                // Make input cover the pill so native click toggling always works
                input.classList.add('tagPillInput--overlay');

                // Initial paint
                const sync = () => label.classList.toggle('is-checked', input.checked);
                sync();

                // Mirror state when user toggles natively
                input.addEventListener('change', sync);

                // Focus ring handling (keyboard)
                input.addEventListener('focus', () => label.classList.add('is-focus'));
                input.addEventListener('blur',  () => label.classList.remove('is-focus'));
            });
        }
    </script>


    <script>
        document.addEventListener('turbo:load', () => {
            const ratingInput = document.getElementById('{{ form.rating.vars.id }}');
            const group   = document.getElementById('starRating');
            const stars   = Array.from(group.querySelectorAll('.star'));
            const counter = document.getElementById('ratingNumber');
            const clamp = (n, a, b) => Math.max(a, Math.min(b, n));

            function setValue(v, focusBtn = true) {
                const val = clamp(parseInt(v, 10) || 1, 1, 10);
                ratingInput.value = val;

                stars.forEach(btn => {
                    const n = parseInt(btn.dataset.value, 10);
                    const isCurrent = n === val;
                    btn.classList.toggle('filled', n <= val);
                    btn.setAttribute('aria-checked', isCurrent ? 'true' : 'false');
                    btn.tabIndex = isCurrent ? 0 : -1;
                });

                if (focusBtn) {
                    const cur = stars.find(b => parseInt(b.dataset.value,10) === val);
                    if (cur) cur.focus();
                }
                counter.textContent = `${val}/10`;
            }

            stars.forEach(btn => btn.addEventListener('click', () => setValue(btn.dataset.value)));

            group.addEventListener('keydown', (e) => {
                const val = parseInt(ratingInput.value || '1', 10);
                if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { e.preventDefault(); setValue(val + 1); }
                else if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { e.preventDefault(); setValue(val - 1); }
                else if (e.key === 'Home') { e.preventDefault(); setValue(1); }
                else if (e.key === 'End')  { e.preventDefault(); setValue(10); }
                else if (e.key === ' ' || e.key === 'Enter') {
                    const focused = document.activeElement.closest('.star');
                    if (focused) { e.preventDefault(); setValue(focused.dataset.value, false); }
                }
            });

            setValue(ratingInput.value || {{ current|default(5) }}, false);
        });
    </script>
{% endblock %}

{% set formVisibleReview = true %}
