{# templates/review/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Moje recenzje{% endblock %}

{% block body %}
    <section class="reviews-page">
        <div class="reviews-header">
            <h1 class="reviews-title">Moje recenzje</h1>
            <a href="{{ path('review_create') }}" class="btn btnPrimary reviews-new-btn">+ Napisz nową</a>
        </div>

        {% if pagination.items is not empty %}
            <table class="reviews-list">
                <thead>
                <tr class="review-card review-card__header">
                    <th>{{ knp_pagination_sortable(pagination, 'Tytuł książki', 'b.title') }}</th>
                    <th>{{ knp_pagination_sortable(pagination, 'Ocena', 'r.rating') }}</th>
                    <th>Komentarz</th>
                    <th>Akcje</th>
                </tr>
                </thead>
                <tbody>
                {% for review in pagination.items %}
                    <tr class="review-card">
                        <td class="review-card__book">
                            <a href="{{ path('book_show', { slug: review.book.slug }) }}">
                                {{ review.book.title }}
                            </a>
                        </td>
                        <td class="review-card__rating">{{ review.rating }}/10</td>
                        <td class="review-card__comment">{{ review.comment|nl2br }}</td>
                        <td class="review-card__actions">
                            <a href="{{ path('review_edit', { id: review.id }) }}" class="btn btnSecondary">Edytuj</a>
                            <a href="{{ path('review_delete', { id: review.id }) }}" class="btn btnDanger">Usuń</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            <nav class="pagination reviews-pagination">
                {{ knp_pagination_render(pagination) }}
            </nav>
        {% else %}
            <p class="reviews-empty">Nie napisałeś jeszcze żadnych recenzji.</p>
        {% endif %}
    </section>
{% endblock %}
