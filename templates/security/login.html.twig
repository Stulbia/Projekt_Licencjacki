{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'title.login_title'|trans }}{% endblock %}

{% block body %}
    <section class="login-page">
        <div class="login-card">
            {% if app.user %}
                <div class="login-session">
                    <p class="login-session__text">{{ 'label.logged_in_as'|trans }} {{ app.user.name }}</p>
                    <a class="btn btn-primary btn-lg" href="{{ path('app_logout') }}">{{ 'action.logout'|trans }}</a>
                </div>
            {% endif %}

            <h1 class="login-title">{{ 'title.login_title'|trans }}</h1>

            {% if error %}
                <div class="alert alert-danger" role="alert">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form class="login-form" method="post" novalidate>
                <div class="form-group">
                    <label class="form-label" for="input-email">{{ 'label.email'|trans }}</label>
                    <input
                            type="email"
                            value="{{ last_username }}"
                            name="email"
                            id="input-email"
                            class="form-control"
                            autocomplete="email"
                            required
                            autofocus
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="input-password">{{ 'label.password'|trans }}</label>
                    <input
                            type="password"
                            name="password"
                            id="input-password"
                            class="form-control"
                            autocomplete="current-password"
                            required
                    >
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="form-check">
                    <input type="checkbox" id="remember-me" name="_remember_me" class="form-check__control">
                    <label for="remember-me" class="form-check__label">{{ 'label.remember_me'|trans }}</label>
                </div>

                <button class="btn btn-primary btn-lg btn-block" type="submit">
                    {{ 'action.sign_in'|trans }}
                </button>

                <div class="login-divider" role="separator" aria-label="or"></div>

                <a class="btn btn-google btn-lg btn-block" href="{{ path('connect_google_start') }}">
                    🔓 Google
                </a>
            </form>
        </div>
    </section>
{% endblock %}
