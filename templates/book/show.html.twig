{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/_book.css') }}">
{% endblock %}

{% block body %}
    <div class="book-show">
        <section class="book-detail-layout">
            <div class="book-cover">
                {% if book.coverFilename %}
                    <img src="{{ asset('uploads/' ~ book.coverFilename) }}" alt="Okładka książki {{ book.title }}">
                {% endif %}
            </div>

            <div class="book-info">
                <h1>{{ book.title }}</h1>
                <p class="book-author"><strong>Autor:</strong> {{ book.author.name ?? 'Nieznany autor' }}</p>
                <p class="book-description">{{ book.description }}</p>

                {% if book.tags|length > 0 %}
                    <div class="book-tags">
                        {% for tag in book.tags %}
                            <span class="badge bgSecondary">{{ tag.title }}</span>
                        {% endfor %}
                    </div>
                {% endif %}

                <a href="{{ path('review_create', {bookId: book.id}) }}" class="btn btnPrimary mt2">➕ Dodaj recenzję</a>
            </div>
        </section>

        <section class="book-reviews">
            <h2>Recenzje</h2>

            {% if book.reviews|length > 0 %}
                {% for review in book.reviews %}
                    <div class="review-comment">
                        <p><strong>{{ review.author.name ?? 'Nieznany użytkownik' }}</strong> — Ocena: {{ review.rating }}/10</p>
                        <p>{{ review.comment }}</p>

                        {% if review.tagAssignments|length > 0 %}
                            <div class="review-tags">
                                {% for assignment in review.tagAssignments %}
                                    <span class="badge bgSecondary">{{ assignment.tag.name }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            {% else %}
                <p><em>Brak recenzji dla tej książki.</em></p>
            {% endif %}
        </section>
    </div>
{% endblock %}
