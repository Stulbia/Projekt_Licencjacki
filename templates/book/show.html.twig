{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
{#    {% set formVisible = formVisible|default(false) %}#}
{#    {% set formVisibleReview = formVisibleReview|default(false) %}#}
    <div class="bookBanner">


            <div class="bookCover">
                {% if book.coverFilename %}
                    <img src="{{ asset('uploads/covers/' ~ book.coverFilename) }}" alt="Okładka książki {{ book.title }}">
                {% else %}
                    <img src="{{ asset('uploads/defaultCover.svg') }}" alt="Domyślna okładka książki {{ book.title }}">
                {% endif %}
            </div>

            <div class="bookInfo">
                <h1 class = "bookTitle">{{ book.title }}</h1>
                <p class="bookAuthor">
                    <strong>Autor:</strong>
                    {% if book.author %}
                        <a href="{{ path('author_show', { id: book.author.id }) }}">{{ book.author }}</a>
                    {% else %}
                        Nieznany autor
                    {% endif %}
                </p>

            </div>

    </div>
        <div class="bookDetail">

                {% if avg and avg >= 1 %}
                    <div class="bookRating">
                        <strong>Średnia ocen:</strong>

                                               <span class="ratingNumber">{{ avg }}/10</span>
                    </div>

                {% else %}
                    <p class="noReviews">Ta książka nie posiada jeszcze ocen.</p>
                {% endif %}

{#                    ///////////////////////////////////////////////////                   #}


            {% if book.tags|length > 0 %}
                <div class="bookTags">
                    {% for tag in book.tags %}
                        <span class="badge bgSecondary">{{ tag.title }}</span>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="bookDescription"> <p> {{ book.description }}  </p> </div>


